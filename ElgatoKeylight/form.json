{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "Hostname",
            "caption": "Hostname / IP Address",
            "placeholder": "e.g. keylight.internal or 192.168.1.100"
        },
        {
            "type": "NumberSpinner",
            "name": "Port",
            "caption": "Port",
            "minimum": 1,
            "maximum": 65535
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Update Interval",
            "minimum": 1,
            "maximum": 3600,
            "suffix": " seconds"
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Update Status",
            "onClick": "ELGATOKEYLIGHT_UpdateStatus($id);"
        },
        {
            "type": "Button",
            "caption": "Identify Lamp",
            "enabled": "$Hostname !== ''",
            "onClick": "ELGATOKEYLIGHT_Identify($id);"
        },
        {
            "type": "Button",
            "caption": "Show Debug Info",
            "enabled": "$Hostname !== ''",
            "onClick": "ELGATOKEYLIGHT_ShowDebugInfo($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Connected"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Hostname not configured"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "Connection failed"
        }
    ]
}
